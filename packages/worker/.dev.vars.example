# Public connection only — https://www.notion.so/my-integrations → Configuration tab
# Use "OAuth client ID" + "OAuth client secret" (NOT the internal integration token).
# Secret is shown once — regenerate if unsure. Add redirect URI in Notion:
#   http://localhost:8787/oauth/notion/callback
NOTION_CLIENT_ID=00000000-0000-0000-0000-000000000000
NOTION_CLIENT_SECRET=secret_regenerate_in_notion_configuration_tab
NOTION_REDIRECT_URI=http://localhost:8787/oauth/notion/callback
# Encrypts Notion/Framer tokens in D1 — openssl rand -base64 32
ENCRYPTION_KEY=your-encryption-key

# Session cookie HMAC — openssl rand -base64 32
SESSION_SIGNING_SECRET=your-session-signing-secret

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8787/auth/google/callback

# Web app base (same origin as worker for local dogfood — overrides wrangler.toml prod URL)
WEB_APP_URL=http://localhost:8787
WORKER_PUBLIC_URL=http://localhost:8787

# Dev only: skip subscription check on Google login (remove in production)
AUTH_DEV_ALLOW_ANY=true

# Billing — Polar sandbox (https://sandbox.polar.sh)
BILLING_PROVIDER=polar
BILLING_WEBHOOK_SECRET=
# One checkout link per product (Polar → Checkout Links → copy redirect URL)
BILLING_CHECKOUT_URL_PRO=https://sandbox-api.polar.sh/v1/checkout-links/polar_cl_.../redirect
BILLING_CHECKOUT_URL_MAX=https://sandbox-api.polar.sh/v1/checkout-links/polar_cl_.../redirect
# Customer portal — Polar → Settings → Organization (slug) → https://polar.sh/<slug>/portal
BILLING_CUSTOMER_PORTAL_URL=https://polar.sh/your-org-slug/portal
# Legacy fallback for Pro only if BILLING_CHECKOUT_URL_PRO is unset:
# BILLING_CHECKOUT_URL=
# Webhook plan mapping — product IDs from Polar → Products (prod_…), NOT checkout URLs:
# POLAR_PRO_PRODUCT_ID=prod_...
# POLAR_MAX_PRODUCT_ID=prod_...
