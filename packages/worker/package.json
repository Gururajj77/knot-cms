{
  "name": "@notion-framer/worker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "wrangler deploy --dry-run --outdir=dist",
    "typecheck": "tsc --noEmit",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply notion_framer_sync --local",
    "db:migrate:remote": "wrangler d1 migrations apply notion_framer_sync --remote",
    "license:generate": "tsx scripts/generate-license.ts"
  },
  "dependencies": {
    "@notion-framer/shared": "*",
    "framer-api": "^0.1.10",
    "hono": "^4.7.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250320.0",
    "tsx": "^4.19.3",
    "typescript": "^5.9.2",
    "wrangler": "^4.4.0"
  }
}
