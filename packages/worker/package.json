{
  "name": "@knotcms/worker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "wrangler deploy --dry-run --outdir=dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply publishflow --local",
    "db:migrate:remote": "wrangler d1 migrations apply publishflow --remote",
    "release": "npm run db:migrate:remote && npm run deploy",
    "triggers:clear": "wrangler triggers deploy --name notion-framer-sync"
  },
  "dependencies": {
    "@knotcms/shared": "*",
    "@polar-sh/sdk": "^0.48.1",
    "framer-api": "^0.1.10",
    "hono": "^4.7.4"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.13",
    "@cloudflare/workers-types": "^4.20250320.0",
    "tsx": "^4.19.3",
    "typescript": "^5.9.2",
    "vitest": "^4.1.8",
    "wrangler": "^4.4.0"
  }
}
